OPENROUTER_API_KEY=sk-or-...
HONCHO_API_KEY=
HONCHO_BASE_URL=https://api.honcho.dev
HONCHO_WORKSPACE_ID=

# ── Hosted-deploy extras (Fly.io + Cloudflare + Clerk) ─────────────────────

# Where SQLite + uploads + WAL files live. Defaults to ./data in dev; in
# production point at the mounted persistent volume (e.g. /data on Fly).
DATA_DIR=

# Clerk (third-party auth). CLERK_ISSUER is the Clerk Frontend API URL — copy
# it from Clerk dashboard -> Developers -> API Keys -> "Frontend API". Used to
# fetch JWKs and validate `iss` on inbound session tokens.
CLERK_ISSUER=
# Optional: only required if you set an "audience" claim on a custom JWT
# template in Clerk. Leave empty to skip audience checks.
CLERK_AUDIENCE=

# At-rest encryption key for BYOK credentials (OpenRouter / Jina API keys
# users paste in the settings UI). Any long random string. MUST be stable
# across restarts or stored BYOK values become unreadable.
BYOK_ENC_KEY=

# Default monthly free LLM budget per account (USD). Users on BYOK skip
# this entirely. Default 0.30 if unset.
DEFAULT_MONTHLY_BUDGET_USD=0.30

# Per-user request rate limit (per minute). Default 60.
RATE_LIMIT_PER_MIN=60

# Comma-separated CORS allowlist. Leave empty during dev to echo any origin.
# In production set to e.g. https://app.your-domain.com
CORS_ALLOWED_ORIGINS=
